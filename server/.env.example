# Copie para ".env" e ajuste.

# Qual backend usar por padrão:  api  |  subscription
DEFAULT_BACKEND=api

# ---- Backend "api" (pago por token) --------------------------------------
# Pegue a chave em https://console.anthropic.com/settings/keys
# IMPORTANTE p/ o modo assinatura: deixe a chave SÓ aqui no .env, nunca como
# variável de ambiente do sistema — senão o Claude Code a herda e cobra pela
# API em vez de usar sua assinatura.
ANTHROPIC_API_KEY=sk-ant-...

CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=32000

# Quanto o modelo pensa e gasta: low | medium | high | xhigh | max
# "high" equilibra qualidade e custo. "xhigh" é o melhor para trabalho de
# código e agêntico — vale testar se você faz projetos grandes.
CLAUDE_EFFORT=high

# Com quantos tokens de entrada a conversa é resumida sozinha. Mínimo 50000.
# Só vale para os modelos que suportam compactação (opus 4.6+, sonnet 4.6+,
# sonnet 5, fable 5) — em outros o servidor não tenta, e a conversa cresce até
# estourar o contexto.
COMPACT_AT=150000

# ---- Backend "subscription" (sua assinatura Pro/Max) ---------------------
# Requer: pip install claude-agent-sdk  +  login do Claude Code (veja o README).
# Vazio = usa o modelo padrão do Claude Code.
SUBSCRIPTION_MODEL=
MAX_TURNS=80

# ---- Rede ----------------------------------------------------------------
# NÃO troque por 0.0.0.0. A ponte não tem senha: ela é segura porque só escuta
# nesta máquina. Em 0.0.0.0, qualquer um na sua rede pode mandar o Claude
# escrever script e rodar código no seu place.
HOST=127.0.0.1

# Se mudar a porta, mude também a URL na caixa do plugin, dentro do Studio —
# os dois lados precisam bater.
PORT=8787
POLL_TIMEOUT=20

# Alto de propósito: o relógio corre enquanto o card de permissão está aberto
# esperando você decidir.
TOOL_TIMEOUT=300
